# Only track UBND project — ignore everything else at root
/*
!/nghiepvu-ubnd-baria/
!.gitignore

# Secrets — block globally
**/token.json
**/client_secret*.json
**/credentials.json
**/.env
**/.env.local

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# Node
node_modules/
package-lock.json

# Logs
logs/
*.log

# OS
Thumbs.db
.DS_Store
*.swp
*.swo

# IDE
.vscode/
.idea/
