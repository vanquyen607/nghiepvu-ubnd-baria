# OpenClaw UBND Bà Rịa — Cấu hình môi trường (mẫu)
# ============================================================

# Anthropic API (đặt giá trị thực tế ở .env)
ANTHROPIC_API_KEY=sk-***

# Google API Key (có thể không dùng)
GOOGLE_API_KEY=AIzaSy***

# Google OAuth credentials (đặt tên file JSON ở đây)
GOOGLE_CREDENTIALS_PATH=client_secret.json
TOKEN_PATH=token.json

# Google Calendar (primary hoặc ID của Calendar)
GOOGLE_CALENDAR_ID=primary

# Google Sheets ID (sau khi tạo Sheet)
GOOGLE_SHEET_TASK_ID=your-task-sheet-id
GOOGLE_SHEET_LICH_ID=your-schedule-sheet-id

# Google Drive folder ID (đặt "root" để dùng thư mục gốc)
GDRIVE_KET_LUAN_FOLDER_ID=your-folder-id

# Email gửi thông báo
NOTIFICATION_EMAIL=your-email@example.com

# Flask (đặt giá trị bí mật tùy ý)
FLASK_SECRET_KEY=change-me-in-production

# Cấu hình hệ thống
LOG_LEVEL=INFO
LOG_DIR=logs/
OUTPUT_DIR=output/